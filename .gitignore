# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# IDE settings
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Python test/cache
.pytest_cache/
.mypy_cache/

# Build output
build/
dist/
*.egg-info/

# Runtime logs
*.log

# Database (local test data)
MobilePartsDB_v1/Database/
*.db
*.sqlite
*.sqlite3

# User photos / attachments
MobilePartsDB_v1/Photos/
MobilePartsDB_v1/TestAttachments/

# Temporary backups
*.bak
*.tmp